# -*- mode: ruby -*-
# vi: set ft=ruby :

# ============================================================
#  k8s-observability-platform — Vagrantfile
#  Topology : 1 Master  +  2 Workers
#  Network  : 192.168.56.0/24  (VirtualBox host-only)
#  MetalLB  : 192.168.56.200 – 192.168.56.250  (Phase 02)
# ============================================================

BOX_IMAGE   = "bento/ubuntu-25.04"
BOX_VERSION = "202510.26.0"

NODES = [
  { name: "k8s-master",   ip: "192.168.56.10", cpus: 3, memory: 3072 },
  { name: "k8s-worker-1", ip: "192.168.56.11", cpus: 3, memory: 3072 },
  { name: "k8s-worker-2", ip: "192.168.56.12", cpus: 3, memory: 3072 },
]

# ------------------------------------------------------------
#  Common bootstrap script — runs on every node before Ansible
#  Sets kernel prerequisites required by Kubernetes
# ------------------------------------------------------------
$bootstrap = <<~SHELL
  set -euo pipefail

  echo ">>> [bootstrap] Disabling swap"
  swapoff -a
  sed -i '/\\bswap\\b/d' /etc/fstab

  echo ">>> [bootstrap] Loading kernel modules"
  cat <<EOF > /etc/modules-load.d/k8s.conf
overlay
br_netfilter
EOF
  modprobe overlay
  modprobe br_netfilter

  echo ">>> [bootstrap] Applying sysctl settings"
  cat <<EOF > /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
EOF
  sysctl --system > /dev/null

  echo ">>> [bootstrap] Done — node is ready for Ansible"
SHELL

# ============================================================
Vagrant.configure("2") do |config|

  config.vm.box         = BOX_IMAGE
  config.vm.box_version = BOX_VERSION

  # Ansible will handle all provisioning — no need for the default share
  config.vm.synced_folder ".", "/vagrant", disabled: true

  NODES.each do |node|
    config.vm.define node[:name] do |machine|

      machine.vm.hostname = node[:name]
      machine.vm.network "private_network", ip: node[:ip]

      machine.vm.provider "virtualbox" do |vb|
        vb.name   = node[:name]
        vb.cpus   = node[:cpus]
        vb.memory = node[:memory]
        vb.gui    = false

        # Suppress verbose VirtualBox output
        vb.customize ["modifyvm", :id, "--uart1", "0x3F8", "4"]
        vb.customize ["modifyvm", :id, "--uartmode1", "file", File::NULL]
      end

      machine.vm.provision "shell", inline: $bootstrap

    end
  end

end
